{
  "mode": {
    "startMinimizedToTray": true,
    "autoIntervalMs": 10000,
    "showControlPanelOnStart": false
  },
  "hotkeys": {
    "singleOcr": "Ctrl+Alt+O",
    "singleOcrTranslate": "Ctrl+Alt+T",
    "regionOcr": "Ctrl+Alt+R",
    "regionOcrTranslate": "Ctrl+Alt+Y",
    "toggleAutoOcr": "Ctrl+Alt+A",
    "toggleAutoTranslate": "Ctrl+Alt+S",
    "toggleAutoRegionTranslate": "Ctrl+Alt+U",
    "clearOverlay": "Ctrl+Alt+C",
    "exit": "Ctrl+Alt+Q"
  },
  "ocr": {
    "provider": "noop",
    "skipIfScreenshotUnchanged": true,
    "postProcessing": {
      "enabled": true,
      "removeControlCharacters": true,
      "normalizeWhitespace": true,
      "dropPunctuationOnly": true,
      "dropShortIsolatedText": true,
      "mergeNearbyTextRegions": true,
      "mergeNearbyLinesIntoBlocks": true,
      "dropOverlappingDuplicates": true,
      "minMeaningfulCharacters": 1,
      "minTextLength": 1,
      "minConfidence": 0.35,
      "minRegionWidth": 12,
      "minRegionHeight": 8,
      "minRegionArea": 72,
      "shortTextMaxLength": 3,
      "sameLineVerticalTolerancePx": 10,
      "sameLineMaxHorizontalGapPx": 28,
      "sameBlockMaxVerticalGapPx": 32,
      "duplicateOverlapRatio": 0.82,
      "maxRegions": 80,
      "charactersToRemove": "\u200B\u200C\u200D\uFEFF¦|"
    },
    "imagePreprocessing": {
      "enabled": true,
      "scale": 2,
      "maxLongSide": 3840,
      "grayscale": true,
      "contrast": 1.35,
      "brightness": 0
    },
    "paddle": {
      "executable": "paddleocr.exe",
      "argumentsTemplate": "--image_dir \"{image}\" --use_angle_cls {useAngleCls} --lang {lang} --type ocr {modelArgs}",
      "timeoutMs": 15000,
      "useImportedModels": false,
      "modelRoot": "",
      "detectionModelDir": "",
      "recognitionModelDir": "",
      "classificationModelDir": "",
      "recCharDictPath": "",
      "language": "ch",
      "useAngleCls": true
    },
    "onnx": {
      "modelRoot": "",
      "detectionModelPath": "",
      "recognitionModelPath": "",
      "classificationModelPath": "",
      "recCharDictPath": "",
      "detLimitSideLen": 2048,
      "detThreshold": 0.2,
      "boxThreshold": 0.35,
      "unclipRatio": 1.8,
      "minBoxSize": 6,
      "recImageHeight": 48,
      "recImageWidth": 480,
      "intraOpNumThreads": 2
    }
  },
  "translation": {
    "provider": "noop",
    "sourceLanguage": "auto",
    "targetLanguage": "zh",
    "rps": 2,
    "timeoutMs": 15000,
    "baidu": {
      "endpoint": "https://fanyi-api.baidu.com/api/trans/vip/translate",
      "appId": "",
      "secret": ""
    },
    "google": {
      "endpoint": "https://translation.googleapis.com/language/translate/v2",
      "apiKey": "",
      "bearerToken": ""
    },
    "http": {
      "endpoint": "http://localhost:8000/v1/chat/completions",
      "method": "POST",
      "apiKey": "",
      "headersJson": {
        "Content-Type": "application/json"
      },
      "bodyContentType": "application/json",
      "bodyTemplate": {
        "model": "local",
        "messages": [
          {
            "role": "system",
            "content": "{prompt}"
          },
          {
            "role": "user",
            "content": "{text}"
          }
        ],
        "stream": true
      },
      "prompt": "将 OCR 提取的游戏内文本翻译为中文。在没有官方译名的情况下，地名和人名不要翻译。只返回翻译结果，不要任何多余的文本。",
      "responseFieldPath": "choices.0.message.content",
      "streamMode": "sse",
      "streamDeltaFieldPath": "choices.0.delta.content"
    }
  },
  "overlay": {
    "showOriginalWhenNoTranslation": true,
    "opacity": 0.5,
    "fontName": "Microsoft YaHei UI",
    "fontSize": 10,
    "foreground": "#FFFFFF",
    "background": "#202020"
  },
  "performance": {
    "cpuThreads": 2,
    "cpuAffinityMask": "",
    "memorySoftLimitMb": 800,
    "enableTranslationCache": true,
    "skipTranslationWhenOcrUnchanged": true
  },
  "plugins": {
    "enabled": false,
    "directory": "plugins",
    "requireManifest": true,
    "approvedNetworkHosts": ""
  }
}
